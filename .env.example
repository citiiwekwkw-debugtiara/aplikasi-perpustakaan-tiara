# Database Configuration (Aiven MySQL)
# Copy credential ini dari Aiven Console -> Services -> Your Service -> Connection Info

DB_HOST=your-mysql-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASS=your-password-here
DB_NAME=defaultdb

# Untuk development lokal (XAMPP), ubah menjadi:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=
# DB_NAME=ukk_perpustakaan
