{
  "builds": [
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}